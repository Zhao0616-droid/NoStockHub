{
  "info": {
    "name": "NoStockHub API Tests",
    "description": "NoStockHub Backend API Test Collection\nBase URL: http://127.0.0.1:8000/api\nAuth: Bearer JWT\n\nUsage:\n1. Import into Postman (VS Code or Desktop)\n2. Run 'Auth > Login' first to get token\n3. Run remaining folders in order",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{access_token}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000/api" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "project_id", "value": "" },
    { "key": "task_id", "value": "" },
    { "key": "task2_id", "value": "" },
    { "key": "sprint_id", "value": "" },
    { "key": "board_id", "value": "" },
    { "key": "worklog_id", "value": "" },
    { "key": "report_id", "value": "" }
  ],
  "item": [
    {
      "name": "1-Auth",
      "item": [
        {
          "name": "Login (valid)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Has access token', () => pm.expect(json.token.access).to.be.a('string'));",
                "pm.collectionVariables.set('access_token', json.token.access);",
                "pm.collectionVariables.set('refresh_token', json.token.refresh);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": { "raw": "{{base_url}}/auth/login/", "host": ["{{base_url}}"], "path": ["auth", "login", ""] },
            "body": { "mode": "raw", "raw": "{\"username\":\"test\",\"password\":\"123456\"}" }
          }
        },
        {
          "name": "Login (wrong password)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 400', () => pm.response.to.have.status(400));",
                "const body = pm.response.text();",
                "pm.test('Error message', () => pm.expect(body).to.include('error'));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": { "raw": "{{base_url}}/auth/login/", "host": ["{{base_url}}"], "path": ["auth", "login", ""] },
            "body": { "mode": "raw", "raw": "{\"username\":\"test\",\"password\":\"wrong_password\"}" }
          }
        },
        {
          "name": "Login (missing fields)",
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 400', () => pm.response.to.have.status(400));"] }
          }],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": { "raw": "{{base_url}}/auth/login/", "host": ["{{base_url}}"], "path": ["auth", "login", ""] },
            "body": { "mode": "raw", "raw": "{\"username\":\"test\"}" }
          }
        },
        {
          "name": "Register (new user)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const code = pm.response.code;",
                "pm.test('Status 201 or 400', () => pm.expect(code).to.be.oneOf([201, 400]));",
                "if (code === 201) pm.test('Has token', () => pm.expect(pm.response.json().token).to.exist);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": { "raw": "{{base_url}}/auth/register/", "host": ["{{base_url}}"], "path": ["auth", "register", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"newman_test\",\"email\":\"newman@test.com\",\"password\":\"Abc@123456\",\"password2\":\"Abc@123456\",\"phone\":\"13800000000\"}"
            }
          }
        },
        {
          "name": "Token Refresh",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.collectionVariables.set('access_token', json.access);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": { "raw": "{{base_url}}/auth/token/refresh/", "host": ["{{base_url}}"], "path": ["auth", "token", "refresh", ""] },
            "body": { "mode": "raw", "raw": "{\"refresh\":\"{{refresh_token}}\"}" }
          }
        },
        {
          "name": "Get Profile",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Has username', () => pm.expect(pm.response.json().username).to.be.a('string'));"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/auth/profile/", "host": ["{{base_url}}"], "path": ["auth", "profile", ""] }
          }
        },
        {
          "name": "Change Password",
          "event": [{
            "listen": "test",
            "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] }
          }],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": { "raw": "{{base_url}}/auth/change-password/", "host": ["{{base_url}}"], "path": ["auth", "change-password", ""] },
            "body": { "mode": "raw", "raw": "{\"old_password\":\"123456\",\"new_password\":\"123456\"}" }
